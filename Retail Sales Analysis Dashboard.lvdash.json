{
  "datasets": [
    {
      "name": "retail_metrics",
      "displayName": "Retail Metrics",
      "config": {
        "source": "retail_q.retail_semantic.retail_metrics",
        "measures": [
          {
            "displayName": "Total Revenue",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "total_revenue",
            "expr": "MEASURE(`Total Revenue`)",
            "comment": "Total revenue from all transactions"
          },
          {
            "displayName": "Total Quantity",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "total_quantity",
            "expr": "MEASURE(`Total Quantity`)",
            "comment": "Total quantity of products sold"
          },
          {
            "displayName": "Total Discount",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "total_discount",
            "expr": "MEASURE(`Total Discount`)",
            "comment": "Total discount amount applied"
          },
          {
            "displayName": "Transaction Count",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 0.0
              }
            },
            "name": "transaction_count",
            "expr": "MEASURE(`Transaction Count`)",
            "comment": "Number of transactions"
          },
          {
            "displayName": "Average Order Value",
            "format": {
              "type": "currency",
              "currencyCode": "USD",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            },
            "name": "avg_order_value",
            "expr": "MEASURE(`Average Order Value`)",
            "comment": "Average revenue per transaction"
          }
        ],
        "version": "1.1",
        "comment": "Retail sales analysis with comprehensive metrics and dimensions",
        "dimensions": [
          {
            "name": "transaction_date",
            "expr": "`Transaction Date`",
            "displayName": "Transaction Date",
            "comment": "Date when the transaction occurred"
          },
          {
            "name": "product_name",
            "expr": "`Product Name`",
            "displayName": "Product Name",
            "comment": "Name of the product sold"
          },
          {
            "name": "product_segment",
            "expr": "`Product Segment`",
            "displayName": "Product Segment",
            "comment": "Market segment of the product"
          },
          {
            "name": "sales_channel",
            "expr": "`Sales Channel`",
            "displayName": "Sales Channel",
            "comment": "Channel through which the sale was made"
          },
          {
            "name": "payment_mode",
            "expr": "`Payment Mode`",
            "displayName": "Payment Mode",
            "comment": "Method of payment used for the transaction"
          }
        ]
      }
    }
  ],
